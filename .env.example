# Copy this file to .env and fill in your values
VITE_APP_PASSWORD=choose-a-private-access-password
# Base32 secrets for Microsoft Authenticator (generate: npx otpauth secret)
VITE_APP_TOTP_SECRET=BASE32SECRETFORAPPLOGIN
VITE_REVENUE_TOTP_SECRET=BASE32SECRETFORREVENUE
# Legacy static PIN (only used if VITE_REVENUE_TOTP_SECRET is empty)
VITE_REVENUE_PIN=
VITE_DEMO_MODE=false
VITE_GEMINI_API_KEY=your-primary-gemini-key
VITE_GEMINI_API_KEY2=your-second-gemini-key
VITE_GEMINI_API_KEY3=your-third-gemini-key
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here
VITE_SHEETS_WEBHOOK=https://script.google.com/macros/s/YOUR_DEPLOYMENT_ID/exec
