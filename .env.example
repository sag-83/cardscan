# Copy this file to .env and fill in your values
# Optional: legacy app password (ignored when VITE_APP_TOTP_SECRET is set)
VITE_APP_PASSWORD=
# Base32 secrets for Microsoft Authenticator (app login = code + Face ID, no password)
VITE_APP_TOTP_SECRET=BASE32SECRETFORAPPLOGIN
# PIN used when Microsoft Authenticator is toggled off in Settings (requires VITE_APP_TOTP_SECRET)
VITE_APP_PIN=
VITE_REVENUE_TOTP_SECRET=BASE32SECRETFORREVENUE
# Revenue PIN — used when authenticator is toggled off, or when VITE_REVENUE_TOTP_SECRET is empty
VITE_REVENUE_PIN=
VITE_DEMO_MODE=false
VITE_GEMINI_API_KEY=your-primary-gemini-key
VITE_GEMINI_API_KEY2=your-second-gemini-key
VITE_GEMINI_API_KEY3=your-third-gemini-key
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here
VITE_SHEETS_WEBHOOK=https://script.google.com/macros/s/YOUR_DEPLOYMENT_ID/exec

# Follow-up push when app is closed (generate: npx web-push generate-vapid-keys)
VITE_VAPID_PUBLIC_KEY=
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@example.com
# Vercel cron + push-subscribe API (never expose in client)
SUPABASE_SERVICE_ROLE_KEY=
CRON_SECRET=random-long-string
# Reminder cron: Vercel Hobby allows at most once/day in vercel.json (use Pro for */5).
# On Hobby, ping every 5 min via cron-job.org → GET your-app.vercel.app/api/cron/followup-reminders
# Header: Authorization: Bearer <CRON_SECRET>
