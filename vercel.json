{
  "headers": [
    {
      "source": "/",
      "headers": [{ "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }]
    },
    {
      "source": "/index.html",
      "headers": [{ "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }]
    },
    {
      "source": "/dashboard",
      "headers": [{ "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }]
    },
    {
      "source": "/dashboard.html",
      "headers": [{ "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }]
    }
  ],
  "rewrites": [
    { "source": "/dashboard", "destination": "/dashboard.html" },
    { "source": "/((?!api|dashboard\\.html|assets|sw\\.js|manifest\\.webmanifest|delta-logo\\.png|app-icon\\.png|app-icon-192\\.png|apple-touch-icon\\.png|apple-touch-icon-120\\.png|apple-touch-icon-152\\.png|apple-touch-icon-167\\.png|favicon\\.png|login-bg\\.jpg|amit-brochure\\.pdf|amit-brochure\\.png|my-contact-qr\\.png).*)", "destination": "/index.html" }
  ]
}
